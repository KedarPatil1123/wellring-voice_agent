# WellRing Voice Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local SQLite path (default if Supabase is not enabled)
WELLRING_DB_PATH=wellring.db

# ---------------------------------------------------------------------------
# Supabase (Production PostgreSQL)
# ---------------------------------------------------------------------------
USE_SUPABASE=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ---------------------------------------------------------------------------
# Twilio (Real SMS alerts)
# ---------------------------------------------------------------------------
USE_TWILIO=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_PHONE=+1234567890

# ---------------------------------------------------------------------------
# Caregiver
# ---------------------------------------------------------------------------
CAREGIVER_PHONE=+0987654321

# ---------------------------------------------------------------------------
# Gemini API
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key

# ---------------------------------------------------------------------------
# Vapi & Cartesia
# ---------------------------------------------------------------------------
CARTESIA_API_KEY=your_cartesia_api_key
VAPI_SERVER_KEY=your_vapi_server_key
VAPI_CLIENT_KEY=your_vapi_client_key
